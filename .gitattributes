###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text=auto eol=lf

###############################################################################
# C# and .NET project files
###############################################################################
*.cs     text eol=lf
*.csproj text eol=lf
*.slnx   text eol=lf
*.sln    text eol=lf

###############################################################################
# Web and config files
###############################################################################
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.xml    text eol=lf
*.xaml   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.config text eol=lf
*.props  text eol=lf

###############################################################################
# Shell and CI scripts
###############################################################################
*.sh     text eol=lf
*.ps1    text eol=lf

###############################################################################
# Binary files - never modify line endings
###############################################################################
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary
*.pdf    binary
*.zip    binary
